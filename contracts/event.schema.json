{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Event",
    "type": "object",
    "required": ["user_id", "type", "timestamp", "transaction_id"],
    "properties": {
        "event_id": { "type": "integer" },
        "user_id": { "type": "string" },
        "type": {
            "type": "string",
            "enum": ["purchase", "view", "add_to_cart", "remove_from_cart", "return", "review", "wishlist", "click"]
        },
        "transaction_id": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "context": { "type": "object" }
    }
}